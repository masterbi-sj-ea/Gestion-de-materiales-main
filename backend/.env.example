NODE_ENV=development
PORT=4009
# En desarrollo/LAN usa 0.0.0.0. Detrás de IIS en producción usa 127.0.0.1.
HOST=0.0.0.0
TRUST_PROXY=false

# Orígenes permitidos para CORS y Socket.IO cuando el frontend no corre en el mismo origin.
# Separar múltiples valores por coma. En producción, si se deja vacío,
# el backend solo aceptará mismo origen y requests sin cabecera Origin.
CORS_ALLOWED_ORIGINS=

DB_SERVER=
DB_USER=
DB_PASSWORD=
DB_DATABASE=GestionMateriales
DB_ENCRYPT=false
DB_CONNECTION_TIMEOUT_MS=30000
DB_REQUEST_TIMEOUT_MS=120000
DB_LOG_SLOW_MS=2000

JWT_SECRET=change-me-in-production

# Tipo de cambio usado para normalizar importaciones de materiales a USD.
MATERIALES_TIPO_CAMBIO_USD_TO_CORD=36.80

# Carpeta raíz de imágenes de materiales (opcional).
MATERIALES_IMG_ROOT=

# Carpeta de cache local para imágenes optimizadas (opcional).
MATERIALES_IMG_CACHE=

WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:tu-correo@empresa.com

HTTPS_KEY_PATH=
HTTPS_CERT_PATH=