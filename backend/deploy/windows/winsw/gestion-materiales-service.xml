<service>
  <id>gestion-materiales-backend</id>
  <name>Gestion Materiales Backend</name>
  <description>Backend Node.js de Gestion de Materiales para Windows Server.</description>
  <executable>C:\Program Files\nodejs\node.exe</executable>
  <arguments>dist\server.js</arguments>
  <workingdirectory>%BASE%</workingdirectory>
  <stoptimeout>10 sec</stoptimeout>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="20 sec" />
  <onfailure action="none" />
  <env name="NODE_ENV" value="production" />
  <env name="PORT" value="4009" />
  <env name="HOST" value="127.0.0.1" />
  <env name="TRUST_PROXY" value="true" />
  <log mode="roll-by-size-time">
    <sizeThreshold>10240</sizeThreshold>
    <pattern>yyyyMMdd</pattern>
    <keepFiles>14</keepFiles>
  </log>
</service>