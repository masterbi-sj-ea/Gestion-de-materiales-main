NODE_ENV=production
PORT=4009
HOST=127.0.0.1
TRUST_PROXY=true

# Si IIS publica la app y el navegador entra por el mismo host público,
# puedes dejar esta allowlist vacía.
CORS_ALLOWED_ORIGINS=

DB_SERVER=
DB_USER=
DB_PASSWORD=
DB_DATABASE=GestionMateriales
DB_ENCRYPT=false
DB_CONNECTION_TIMEOUT_MS=30000
DB_REQUEST_TIMEOUT_MS=120000
DB_LOG_SLOW_MS=2000

JWT_SECRET=change-me-in-production
MATERIALES_TIPO_CAMBIO_USD_TO_CORD=36.80
MATERIALES_IMG_ROOT=
MATERIALES_IMG_CACHE=./cache/materiales

WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:tu-correo@empresa.com

# Normalmente el TLS termina en IIS; deja estas variables vacías
# salvo que quieras que Node sirva HTTPS por sí mismo.
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=