# Ejemplo de configuración de variables de entorno para Vite
# Copia este archivo a `.env` y ajusta los valores según tu entorno

# URL base del backend.
# En producción, si el backend sirve el frontend desde el mismo origin público,
# puedes dejar esta variable sin definir y la app usará automáticamente el mismo origin.
VITE_API_URL=http://localhost:4000

# Socket.IO: por defecto usa el mismo origin del API.
# Si el origin final es HTTPS, el frontend entra automáticamente en modo auto
# (polling inicial + upgrade a websocket). Si el origin es HTTP/IP, cae a polling.
# Valores válidos: polling | websocket | auto
# VITE_SOCKET_TRANSPORT=auto
# VITE_SOCKET_URL=http://localhost:4000

# Backend: raíz de imágenes en NAS / disco (UNC path)
# Nota: este .env.example es compartido; en tu .env real puedes usar también la variante con escapes.
MATERIALES_IMG_ROOT=\\NAS02\Desarollo\Imagenes_items
