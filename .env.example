# Ejemplo de configuración de variables de entorno para Vite
# Copia este archivo a `.env` y ajusta los valores según tu entorno

# URL base del backend
VITE_API_URL=http://localhost:4000

# Backend: raíz de imágenes en NAS / disco (UNC path)
# Nota: este .env.example es compartido; en tu .env real puedes usar también la variante con escapes.
MATERIALES_IMG_ROOT=\\NAS02\Desarollo\Imagenes_items
